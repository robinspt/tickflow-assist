{
  "id": "tickflow-assist",
  "name": "TickFlow Assist",
  "version": "0.1.0",
  "description": "A-share watchlist analysis, monitoring, and alert delivery powered by TickFlow and OpenClaw.",
  "skills": [
    "skills"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "tickflowApiUrl": {
        "type": "string",
        "default": "https://api.tickflow.org"
      },
      "tickflowApiKey": {
        "type": "string"
      },
      "tickflowApiKeyLevel": {
        "type": "string",
        "enum": ["Free", "Start", "Pro", "Expert"],
        "default": "Free"
      },
      "mxSearchApiUrl": {
        "type": "string",
        "default": "https://mkapi2.dfcfs.com/finskillshub/api/claw"
      },
      "mxSearchApiKey": {
        "type": "string",
        "default": ""
      },
      "llmBaseUrl": {
        "type": "string",
        "default": "https://api.openai.com/v1"
      },
      "llmApiKey": {
        "type": "string"
      },
      "llmModel": {
        "type": "string",
        "default": "gpt-4o"
      },
      "databasePath": {
        "type": "string",
        "default": "./data/lancedb"
      },
      "calendarFile": {
        "type": "string",
        "default": "./day_future.txt"
      },
      "requestInterval": {
        "type": "integer",
        "minimum": 5,
        "default": 30
      },
      "dailyUpdateNotify": {
        "type": "boolean",
        "default": true
      },
      "alertChannel": {
        "type": "string",
        "description": "Alert delivery channel, e.g. telegram, qqbot, wecom",
        "default": "telegram"
      },
      "openclawCliBin": {
        "type": "string",
        "default": "openclaw"
      },
      "alertAccount": {
        "type": "string",
        "default": ""
      },
      "alertTarget": {
        "type": "string",
        "description": "Channel target, e.g. Telegram chat ID, qqbot:c2c:OPENID, or WeCom userId/chatId",
        "default": ""
      },
      "pythonBin": {
        "type": "string",
        "default": "uv"
      },
      "pythonArgs": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": ["run", "python"]
      },
      "pythonWorkdir": {
        "type": "string",
        "default": "./python"
      }
    }
  },
  "uiHints": {
    "tickflowApiKey": {
      "label": "TickFlow API Key",
      "sensitive": true
    },
    "tickflowApiKeyLevel": {
      "label": "TickFlow API Key Level"
    },
    "mxSearchApiKey": {
      "label": "MX Search API Key",
      "sensitive": true
    },
    "llmApiKey": {
      "label": "LLM API Key",
      "sensitive": true
    },
    "alertTarget": {
      "label": "Alert Target"
    }
  }
}
