{
  "name": "tickflow-assist",
  "version": "0.2.16",
  "description": "OpenClaw smart stock plugin for A-share investing and watchlist workflows, powered by TickFlow API for realtime monitoring, post-close review, multi-dimensional analysis, key level tracking, and alerts. 面向 A 股投资与盯盘场景的 OpenClaw 智能股票插件，基于 TickFlow API 提供实时监控、收盘后复盘、多维综合分析、关键价位跟踪与告警能力。",
  "license": "MIT",
  "type": "module",
  "main": "dist/plugin.js",
  "bin": {
    "tickflow-assist": "dist/dev/tickflow-assist-cli.js"
  },
  "files": [
    "dist",
    "skills",
    "python",
    "day_future.txt",
    "openclaw.plugin.json",
    "README.md"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "tickflow",
    "stocks",
    "lancedb"
  ],
  "scripts": {
    "build": "node ./scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "prepack": "npm run build && node ./scripts/prepare-package-assets.mjs",
    "postpack": "node ./scripts/restore-package-assets.mjs",
    "test": "npm run build && node --test dist/plugin-registration.test.js dist/tools/test-alert.tool.test.js",
    "community-setup": "node dist/dev/tickflow-assist-cli.js configure-openclaw",
    "tool": "node dist/dev/run-tool.js",
    "monitor-loop": "node dist/dev/run-monitor-loop.js",
    "daily-update-loop": "node dist/dev/run-daily-update-loop.js",
    "validate:mx-search": "npm run build && node dist/dev/validate-mx-search.js"
  },
  "openclaw": {
    "build": {
      "openclawVersion": "2026.3.31"
    },
    "compat": {
      "pluginApi": "2026.3.31",
      "minGatewayVersion": "2026.3.31",
      "builtWithOpenClawVersion": "2026.3.31"
    },
    "extensions": [
      "dist/plugin.js"
    ]
  },
  "exports": {
    ".": "./dist/plugin.js"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.18.2",
    "@sinclair/typebox": "^0.34.48",
    "apache-arrow": "^17.0.0",
    "json5": "^2.2.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "openclaw": "^2026.3.31",
    "typescript": "^5.8.2"
  }
}
